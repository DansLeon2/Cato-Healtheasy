node_modules/
.pnp
.pnp.js
 
# --- Build / Producción ---
dist/
build/
.next/
out/
 
# --- Variables de entorno (¡NUNCA subir esto!) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
 
# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
 
# --- Cache ---
.cache/
.parcel-cache/
.vite/
*.tsbuildinfo
 
# --- Editor / IDE ---
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
 
# --- Testing ---
coverage/
 
# --- Oracle / Base de datos ---
*.dmp
*.log
*.bak
wallet/
tnsnames.ora
sqlnet.ora
 
# --- Archivos temporales ---
*.tmp
*.temp